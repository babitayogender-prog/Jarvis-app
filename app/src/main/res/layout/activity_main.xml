<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF030E1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FF071828"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JARVIS"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FF00CFFF"
            android:letterSpacing="0.3" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○ Phone control: OFF"
            android:textSize="11sp"
            android:textColor="#FFFF8830"
            android:paddingTop="4dp" />

        <Button
            android:id="@+id/enableWake"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ENABLE 24/7 + WAKE WORD"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:background="#FF0A4466"
            android:textColor="#FF00CFFF" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FF061828"
        android:padding="12dp">

        <TextView
            android:id="@+id/agentListText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No agents yet."
            android:textSize="12sp"
            android:textColor="#FF3A6A8A"
            android:fontFamily="monospace" />

        <Button
            android:id="@+id/refreshAgents"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⟳ Refresh agents"
            android:textSize="10sp"
            android:layout_marginTop="6dp"
            android:background="#FF0B2035"
            android:textColor="#FF00CFFF" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/chatLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="12dp" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FF071828"
        android:padding="12dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/inputField"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:hint="Type, or create an agent…"
            android:textColorHint="#FF3A6A8A"
            android:textColor="#FFCCE8F8"
            android:background="#FF0B2035"
            android:padding="14dp"
            android:maxLines="3" />

        <Button
            android:id="@+id/sendButton"
            android:layout_width="56dp"
            android:layout_height="48dp"
            android:text="➤"
            android:textSize="18sp"
            android:background="#FF0A4466"
            android:textColor="#FF00CFFF" />
    </LinearLayout>

</LinearLayout>
